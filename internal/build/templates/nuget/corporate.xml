<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="artifactory-nuget" value="{{NUGET_MIRROR_URL}}" protocolVersion="3" />
  </packageSources>
  <packageSourceCredentials>
    <artifactory-nuget>
      <add key="Username" value="$ARTI_USER" />
      <add key="ClearTextPassword" value="$ARTI_PASSWORD" />
    </artifactory-nuget>
  </packageSourceCredentials>
  <config>
    <add key="globalPackagesFolder" value="/home/build/.nuget/packages" />
    <add key="maxHttpRequestsPerSource" value="16" />
  </config>
</configuration>
