<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="artifactory-nuget" value="{{NUGET_MIRROR_URL}}" protocolVersion="3" />
  </packageSources>
  <packageSourceCredentials>
    <artifactory-nuget>
      <add key="Username" value="$NUGET_MIRROR_USER" />
      <add key="ClearTextPassword" value="$NUGET_MIRROR_PASSWORD" />
    </artifactory-nuget>
  </packageSourceCredentials>
</configuration>
