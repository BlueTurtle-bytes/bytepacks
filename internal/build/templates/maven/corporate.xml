<settings>
  <mirrors>
    <mirror>
      <id>apexpack-mirror</id>
      <mirrorOf>*</mirrorOf>
      <url>{{MAVEN_MIRROR_URL}}</url>
    </mirror>
  </mirrors>
  <servers>
    <server>
      <id>apexpack-mirror</id>
      <username>$MAVEN_MIRROR_USER</username>
      <password>$MAVEN_MIRROR_PASSWORD</password>
    </server>
  </servers>
  <profiles>
    <profile>
      <id>apexpack-mirror</id>
      <repositories>
        <repository>
          <id>apexpack-mirror</id>
          <url>{{MAVEN_MIRROR_URL}}</url>
          <releases><enabled>true</enabled></releases>
          <snapshots><enabled>false</enabled></snapshots>
        </repository>
      </repositories>
      <pluginRepositories>
        <pluginRepository>
          <id>apexpack-mirror</id>
          <url>{{MAVEN_MIRROR_URL}}</url>
          <releases><enabled>true</enabled></releases>
          <snapshots><enabled>false</enabled></snapshots>
        </pluginRepository>
      </pluginRepositories>
    </profile>
  </profiles>
  <activeProfiles>
    <activeProfile>apexpack-mirror</activeProfile>
  </activeProfiles>
</settings>
